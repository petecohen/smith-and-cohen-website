---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const upcoming = (await getCollection('streams'))
  .filter((s) => import.meta.env.DEV || !s.data.draft)
  .filter((s) => s.data.status === 'announced' || s.data.status === 'live')
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const nextStream = upcoming[0];
const nextStreamDate = nextStream?.data.date.toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'long',
});

const links = [
  { label: 'Bandcamp', href: 'https://smithandcohen.bandcamp.com' },
  { label: 'Spotify', href: 'https://open.spotify.com/artist/6JQMn0k6YGtE73ym4KrcOU' },
  { label: 'Second Press', href: 'https://secondpress.com.au/artist/c2529f76-9135-4732-92a9-6bd8c2248dce' },
  { label: 'Subvert', href: 'https://www.subvert.fm/smith-and-cohen' },
  { label: 'Apple Music', href: 'https://music.apple.com/au/artist/smith-cohen/1826886417' },
  { label: 'YouTube', href: 'https://www.youtube.com/@SmithandCohen' },
  { label: 'SoundCloud', href: 'https://soundcloud.com/smithcohen-music' },
  { label: 'Substack', href: 'https://substack.com/@smithandcohen' },
  { label: 'Songkick', href: 'https://www.songkick.com/artists/10274332-smith-and-cohen/calendar' },
  { label: 'Instagram', href: 'https://www.instagram.com/smithandcohen/' },
  { label: 'Facebook', href: 'https://www.facebook.com/smithandcohen' },
];
---

<Layout title="Smith & Cohen" showHeader={false}>
  <!-- Full-bleed band portrait background -->
  <div class="fixed inset-0 z-0">
    <img
      src="/images/band-portrait.jpg"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover opacity-80"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-background)]/85 via-[var(--color-background)]/40 to-transparent"></div>
  </div>

  <div class="relative z-10 min-h-screen flex flex-col">
    <div class="flex-1 flex items-center">
      <div class="max-w-5xl mx-auto px-8 md:px-16 py-20 w-full">
        <h1 class="text-6xl md:text-8xl font-bold tracking-tight mb-10">
          Smith &amp; Cohen
        </h1>

        <ul class="space-y-2.5 mb-8 text-base md:text-lg">
          {links.map(link => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[var(--color-text)] hover:opacity-75 transition-opacity"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <a
          href="https://sodastream.net.au"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors mb-10 italic"
        >
          Previously known as Sodastream →
        </a>

        {nextStream && (
          <a
            href={`/live-streams/${nextStream.id}`}
            class="block mb-8 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
          >
            <span class="tracked text-xs">
              {nextStream.data.status === 'live' ? '● Live now' : 'Coming up'}
            </span>
            {' — '}
            {nextStream.data.title}{nextStream.data.guest && ` with ${nextStream.data.guest}`}
            {nextStream.data.status !== 'live' && ` · ${nextStreamDate}`} →
          </a>
        )}

        <div class="flex items-center gap-3">
          <a href="/live-streams" class="pill">Live Streams</a>
          <a href="/contact" class="pill-ghost">Contact</a>
          <a
            href="https://www.instagram.com/smithandcohen/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center hover:border-[var(--color-text)] transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.5" y2="6.51"></line>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/smithandcohen"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="w-10 h-10 rounded-full border border-[var(--color-border)] flex items-center justify-center hover:border-[var(--color-text)] transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99h-2.54V12h2.54V9.8c0-2.51 1.49-3.89 3.78-3.89 1.09 0 2.24.19 2.24.19v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
