---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Thanks — Smith & Cohen"
  description="Thanks for getting in touch."
>
  <article class="max-w-xl mx-auto px-6 pt-32 pb-16 text-center">
    <p class="tracked text-xs text-[var(--color-text-muted)] mb-4">— Message sent —</p>
    <h1 class="display-title text-4xl md:text-5xl mb-8">Thanks</h1>
    <p class="text-base text-[var(--color-text-muted)] mb-10">
      We'll be in touch as soon as we can.
    </p>
    <a href="/" class="pill-ghost">Back to home</a>
  </article>
</Layout>
