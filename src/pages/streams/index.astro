---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import StreamCard from '../../components/StreamCard.astro';

const all = (await getCollection('streams')).filter(
  (s) => import.meta.env.DEV || !s.data.draft
);

const comingUp = all
  .filter((s) => s.data.status === 'announced' || s.data.status === 'live')
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const archive = all
  .filter((s) => s.data.status === 'archived')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Live Streams — Smith & Cohen"
  description="Collaborative live streams — each session pairs a guest's images, soundscapes, poems or songs with live instrumental response."
>
  <article class="max-w-3xl mx-auto px-6 pt-32 pb-16">
    <header class="text-center mb-16">
      <p class="tracked text-xs text-[var(--color-text-muted)] mb-4">— Sessions —</p>
      <h1 class="display-title text-4xl md:text-5xl mb-6">Live Streams</h1>
      <p class="text-base text-[var(--color-text-muted)] max-w-xl mx-auto">
        Each session has a guest who brings something — images, a soundscape, a poem,
        a song — and we respond live over the top. Streams happen on YouTube; every
        session lives on here afterwards.
      </p>
    </header>

    <section class="mb-16">
      <h2 class="tracked text-xs text-[var(--color-text-muted)] mb-6">Coming up</h2>
      {comingUp.length > 0 ? (
        <div class="space-y-3">
          {comingUp.map((stream) => <StreamCard stream={stream} />)}
        </div>
      ) : (
        <p class="text-[var(--color-text-muted)] border border-[var(--color-border)] px-6 py-8 text-center">
          Nothing scheduled just now — the next session will be announced soon.
        </p>
      )}
    </section>

    {archive.length > 0 && (
      <section>
        <h2 class="tracked text-xs text-[var(--color-text-muted)] mb-6">Past sessions</h2>
        <div class="space-y-3">
          {archive.map((stream) => <StreamCard stream={stream} />)}
        </div>
      </section>
    )}

    <p class="text-center mt-16">
      <a href="/board" class="pill-ghost">Message board →</a>
    </p>
  </article>
</Layout>
